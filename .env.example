# ── Server ────────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=80

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=/data/snake.db

# ── Telegram ──────────────────────────────────────────────────────────────────
# Get token from @BotFather
BOT_TOKEN=your_bot_token_here

# Your deployed frontend URL (set in BotFather → /newapp)
WEBAPP_URL=https://yourdomain.com

# ── CORS (optional, defaults to *) ────────────────────────────────────────────
# ALLOWED_ORIGINS=https://yourdomain.com,https://t.me